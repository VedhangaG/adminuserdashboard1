{
  "identity": {
    "persona": "E1: The Anti-AI Designer",
    "core_principles": [
      "Fusion over Imitation",
      "Emotion First",
      "Content is King",
      "Zoom In",
      "Negative Space",
      "Contrast"
    ],
    "anti_patterns": [
      "Purple/Teal for CTA",
      "Inter everywhere (Visual Monotony)",
      "Center-Everything Disease",
      "Gradient Overload (>20%)"
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Outfit, sans-serif",
      "body": "DM Sans, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scale": {
      "h1": "text-4xl md:text-5xl font-bold tracking-tight",
      "h2": "text-3xl md:text-4xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-medium",
      "body_lg": "text-lg leading-relaxed",
      "body_base": "text-base leading-relaxed text-slate-600",
      "caption": "text-sm text-slate-500 uppercase tracking-wider"
    },
    "import_url": "https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,100..1000&family=Outfit:wght@100..900&display=swap"
  },
  "colors": {
    "palette": {
      "primary": "#A7C7E7",
      "secondary": "#CDB4DB",
      "accent": "#B7E4C7",
      "highlight": "#FFD6A5",
      "background": "#F8F9FA",
      "surface": "#FFFFFF",
      "text_main": "#1e293b",
      "text_muted": "#64748b",
      "border_subtle": "#e2e8f0"
    },
    "tailwind_config_extension": {
      "colors": {
        "pastel-blue": "#A7C7E7",
        "pastel-purple": "#CDB4DB",
        "pastel-mint": "#B7E4C7",
        "pastel-peach": "#FFD6A5",
        "bg-soft": "#F8F9FA",
        "text-main": "#1e293b"
      }
    },
    "usage_rules": {
      "primary_action": "bg-slate-900 text-white hover:bg-slate-800",
      "secondary_action": "bg-white text-slate-900 border border-slate-200 hover:bg-slate-50",
      "accent_usage": "Use pastel colors for backgrounds, badges, charts, and illustrative elements. DO NOT use pastel colors for text."
    }
  },
  "visual_enhancers": {
    "shadows": {
      "card": "0 10px 30px -5px rgba(167, 199, 231, 0.2)",
      "float": "0 20px 40px -5px rgba(0, 0, 0, 0.05)"
    },
    "borders": {
      "soft": "1px solid rgba(0,0,0,0.04)",
      "glass": "1px solid rgba(255,255,255,0.5)"
    },
    "radius": {
      "card": "rounded-2xl",
      "button": "rounded-full"
    },
    "textures": {
      "noise": "url('data:image/svg+xml;base64,...')", 
      "glass": "backdrop-blur-xl bg-white/70"
    }
  },
  "layout_strategy": {
    "dashboard": {
      "grid_mode": "Mode B: High Density",
      "container": "w-full max-w-[1600px] mx-auto p-4 md:p-8",
      "gap": "gap-6"
    },
    "marketing": {
      "grid_mode": "Mode A: Tetris Grid",
      "container": "w-full max-w-7xl mx-auto px-6",
      "gap": "gap-12 md:gap-24"
    }
  },
  "components": {
    "buttons": {
      "default": "px-6 py-2.5 font-medium transition-all active:scale-95",
      "primary": "bg-slate-900 text-white shadow-lg shadow-slate-900/20 hover:shadow-slate-900/30",
      "ghost": "hover:bg-slate-100 text-slate-700"
    },
    "cards": {
      "base": "bg-white rounded-2xl border border-slate-100 shadow-[0_2px_20px_rgba(0,0,0,0.04)]",
      "hover": "hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] hover:-translate-y-1 transition-all duration-300"
    },
    "inputs": {
      "base": "h-11 rounded-lg border-slate-200 focus:border-pastel-blue focus:ring-4 focus:ring-pastel-blue/20 transition-all bg-slate-50/50"
    },
    "path_map": {
      "Button": "/app/frontend/src/components/ui/button.jsx",
      "Input": "/app/frontend/src/components/ui/input.jsx",
      "Card": "/app/frontend/src/components/ui/card.jsx",
      "Dialog": "/app/frontend/src/components/ui/dialog.jsx",
      "Table": "/app/frontend/src/components/ui/table.jsx",
      "Avatar": "/app/frontend/src/components/ui/avatar.jsx",
      "Select": "/app/frontend/src/components/ui/select.jsx",
      "Sonner": "/app/frontend/src/components/ui/sonner.jsx"
    }
  },
  "accessibility": {
    "rules": [
      "Text contrast must meet APCA standards (Use Slate-900 for main text on pastel backgrounds).",
      "Interactive elements must have focus rings.",
      "Images must have alt text.",
      "Animations must respect prefers-reduced-motion."
    ],
    "testing": {
      "attribute": "data-testid",
      "format": "kebab-case (e.g., 'login-submit-button')"
    }
  },
  "motion": {
    "library": "framer-motion",
    "presets": {
      "fade_in": {
        "initial": { "opacity": 0, "y": 10 },
        "animate": { "opacity": 1, "y": 0 },
        "transition": { "duration": 0.4, "ease": "easeOut" }
      },
      "stagger_container": {
        "animate": { "transition": { "staggerChildren": 0.1 } }
      },
      "hover_lift": {
        "whileHover": { "y": -2 },
        "transition": { "duration": 0.2 }
      }
    }
  },
  "charts": {
    "library": "recharts",
    "theme": {
      "colors": ["#A7C7E7", "#CDB4DB", "#B7E4C7", "#FFD6A5", "#F4A261"],
      "grid_color": "#e2e8f0",
      "tooltip_bg": "#ffffff",
      "tooltip_border": "#f1f5f9"
    }
  },
  "image_urls": {
    "hero_bg": "https://images.unsplash.com/photo-1579546929518-9e396f3cc809?q=80&w=2070&auto=format&fit=crop",
    "user_avatar_placeholder": "https://api.dicebear.com/7.x/avataaars/svg?seed=Felix",
    "admin_avatar_placeholder": "https://api.dicebear.com/7.x/avataaars/svg?seed=Aneka",
    "login_illustration": "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=1964&auto=format&fit=crop"
  },
  "instructions_to_main_agent": [
    "Follow the specific Pastel Color Scheme provided in 'colors'.",
    "Use 'Outfit' for headings and 'DM Sans' for body text.",
    "Implement Role-Based Access Control (RBAC) strictly.",
    "Use Shadcn components for interactive elements but customize the styles to match the 'Soft/Pastel' aesthetic (more rounding, softer shadows).",
    "Ensure the Admin Dashboard uses the 'High Density' grid layout.",
    "Use Recharts for all analytics.",
    "Add 'data-testid' to all interactive elements.",
    "Do NOT use pure transparent backgrounds for dropdowns/headers.",
    "Use Sonner for notifications.",
    "Maintain the Project Structure defined in the problem statement."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Do NOT apply universal transition (transition: all).",
    "Do NOT center align the App container.",
    "Use 2-3x more spacing than typical designs.",
    "Every interaction needs micro-animations.",
    "Components MUST use named exports.",
    "Pages MUST use default exports."
  ]
}